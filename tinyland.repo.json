{
	"$schema": "./docs/schemas/tinyland-repo-manifest.schema.json",
	"schema_version": 1,
	"repo": {
		"name": "transfemme-tailoring",
		"github": "Jesssullivan/transfemme-tailoring",
		"domain": "transscendsurvival.org/transfemme-tailoring",
		"description": "Build-log and interactive calculators for tailoring oversized, masculine-cut formalwear into a well-fitted transfeminine silhouette on a treadle Singer."
	},
	"taxonomy": {
		"primary_role": "static-spoke",
		"layers": ["org-wide-repo-contract", "bazel-package-cache-rbe", "static-spoke"]
	},
	"contracts": {
		"agent_contract": "AGENTS.md",
		"just": "Justfile",
		"nix": "flake.nix",
		"github_actions": ".github/workflows",
		"secrets_scan": "gitleaks",
		"conformance": "just conformance"
	},
	"boundaries": {
		"owns_runtime_backend": false,
		"owns_auth": false,
		"owns_payments": false,
		"owns_activitypub_delivery": false,
		"owns_live_broker_fetch": false,
		"owns_static_projection_ingest": false,
		"owns_gitops_apply": false,
		"owns_cloudflare_mutation": false,
		"owns_bazel_module_authority": false
	},
	"authorities": {
		"content_authority": "self",
		"ci_templates": "tinyland-inc/ci-templates",
		"cache_rbe_authority": "tinyland-inc/GloriousFlywheel",
		"tofu_module_authority": "tinyland-inc/GloriousFlywheel",
		"package_registry": "tinyland-inc/bazel-registry"
	},
	"supply_chain": {
		"sbom": {
			"status": "recipe-available",
			"formats": ["CycloneDX JSON", "SPDX JSON"],
			"notes": "Run `just sbom` to generate ignored local SBOM artifacts under build/sbom/. Personal GitHub Pages spoke: org-only surfaces (tofu/, Blahaj lanes, pulse-ingest) are carried documented-but-dormant — see AGENTS.md."
		}
	}
}
